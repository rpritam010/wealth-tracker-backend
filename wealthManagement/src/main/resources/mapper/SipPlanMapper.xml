<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.wealthManagement.wealthManagement.mybatis.mapper.SipPlanMapper">

    <insert id="insertSipPlan"
            parameterType="com.wealthManagement.wealthManagement.pojo.dto.SipPlanDto"
            useGeneratedKeys="true"
            keyProperty="id">

        INSERT INTO m_sip_plan
        (
            portfolio_id,
            asset_id,
            sip_amount,
            sip_frequency,
            sip_day,
            start_date,
            is_active
        )
        VALUES
            (
                #{portfolioId},
                #{assetId},
                #{sipAmount},
                #{sipFrequency},
                #{sipDay},
                #{startDate},
                #{isActive}
            )

    </insert>

</mapper>