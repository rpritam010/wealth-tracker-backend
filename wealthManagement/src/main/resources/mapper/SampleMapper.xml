<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wealthManagement.wealthManagement.mybatis.mapper.AssetDetail">

    <!-- Explicit resultMap to map DB columns to POJO properties -->
    <resultMap id="AssetResultMap" type="com.wealthManagement.wealthManagement.pojo.responseBody.AssetDetailMapper">
        <result property="assetName" column="asset_name" />
        <result property="assetCode" column="asset_code" />
        <result property="issuerName" column="issuer_name" />
        <result property="assetSubType" column="asset_subType" />
        <result property="folioNumber" column="folio_number" />
        <result property="assetTypeCode" column="asset_type_code" />
    </resultMap>

    <select id="selectOne" resultMap="AssetResultMap">
        SELECT 
            a.asset_name,
            a.asset_code,
            a.issuer_name,
            a.asset_subType,
            a.folio_number,
            b.asset_type_code
        FROM m_asset a
        JOIN c_asset_type b ON a.asset_type_id = b.id
    </select>

    <!-- Return all assets for a specific user -->
    <select id="selectAssetsByUserId" parameterType="long" resultMap="AssetResultMap">
        SELECT 
            a.asset_name,
            a.asset_code,
            a.issuer_name,
            a.asset_subType,
            a.folio_number,
            b.asset_type_code
        FROM m_asset a
        JOIN c_asset_type b ON a.asset_type_id = b.id
        WHERE a.user_id = #{userId}
    </select>

</mapper>
