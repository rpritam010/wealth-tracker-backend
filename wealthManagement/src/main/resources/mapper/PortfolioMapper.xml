<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.wealthManagement.wealthManagement.mybatis.mapper.PortfolioMapper">

    <resultMap id="PortfolioDtoMap"
               type="com.wealthManagement.wealthManagement.pojo.dto.PortfolioDto">
        <id     property="id"                   column="id"/>
        <result property="userId"               column="user_id"/>
        <result property="portfolioName"        column="portfolio_name"/>
        <result property="portfolioDescription" column="portfolio_description"/>
    </resultMap>

    <insert id="insertPortfolio"
            parameterType="com.wealthManagement.wealthManagement.pojo.dto.PortfolioDto"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO m_portfolio (user_id, portfolio_name, portfolio_description)
        VALUES (#{userId}, #{portfolioName}, #{portfolioDescription})
    </insert>

    <select id="selectPortfolioByUserId" resultMap="PortfolioDtoMap">
        SELECT * FROM m_portfolio
        WHERE user_id = #{userId}
            LIMIT 1
    </select>

</mapper>